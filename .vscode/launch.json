{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Project Pulse Dashboard",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}/app",
      "runtimeExecutable": "python3",
      "runtimeArgs": [
        "-m",
        "http.server",
        "5500"
      ],
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "port (\\\\d+)",
        "uriFormat": "http://localhost:%s/index.html",
        "action": "openExternally"
      }
    }
  ]
}
